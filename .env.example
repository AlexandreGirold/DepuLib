# --- Cloud Temple LLMaaS (IA souveraine SecNumCloud) ---
# Documentation : https://docs.cloud-temple.com/llmaas
# Exemples officiels : https://github.com/Cloud-Temple/product-llmaas-how-to
CLOUDTEMPLE_LLMAAS_API_KEY=
CLOUDTEMPLE_LLMAAS_BASE_URL=https://api.ai.cloud-temple.com/v1
# Modèle principal : Mistral Small 4 (catalogue Cloud Temple LLMaaS)
LLM_MODEL_MAIN=mistral-small4:119b
LLM_MODEL_FAST=mistral-small4:119b
LLM_MODEL_EMBED=bge-m3:567m
LLM_TIMEOUT_MS=20000

# --- MCP Assemblée nationale (tricoteuses) ---
MCP_TRICOTEUSES_URL=https://www.tricoteuses.fr/mcp
MCP_TIMEOUT_MS=15000

# --- Stockage documents (OVH Object Storage, compatible S3) ---
# Générés par Terraform (infra/). Vides → fallback disque local (UPLOAD_DIR).
S3_ENDPOINT=
S3_REGION=gra
S3_BUCKET=depulib-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Actualités « ce qui change » (info.gouv.fr) ---
# Le domaine info.gouv.fr est protégé par Cloudflare (challenge anti-bot) : pas de
# scraping en direct. Les pages sont téléchargées à la main dans seed/actus/YYYY_MM.html.
#   npm run parse-actus  → parse le HTML + classe (100 % déterministe) → seed/actus.json (versionné)
#   npm run seed-actus   → charge seed/actus.json en base
# Aucune clé requise : le pipeline actus est entièrement hors-ligne et déterministe.

# --- Application ---
SESSION_SECRET=depulib-poc-changez-moi-32-caracteres
DATABASE_URL=file:/data/depulib.db
UPLOAD_DIR=/data/uploads
NEXT_PUBLIC_APP_NAME=Depulib

export OVH_ENDPOINT="ovh-eu"
export OVH_APPLICATION_KEY="ta_application_key"
export OVH_APPLICATION_SECRET="ta_application_secret"
export OVH_CONSUMER_KEY="ta_consumer_key"

export OVH_CLOUD_PROJECT_SERVICE="ton_project_id"
# Clé SSH publique injectée dans la VM (variable Terraform ssh_public_key)
export OVH_API_KEY="ssh-ed25519 AAAA... ovh-terraform-poc"