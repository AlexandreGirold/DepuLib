# --- Cloud Temple LLMaaS (IA souveraine SecNumCloud) ---
# Documentation : https://docs.cloud-temple.com/llmaas
# Exemples officiels : https://github.com/Cloud-Temple/product-llmaas-how-to
CLOUDTEMPLE_LLMAAS_API_KEY=
CLOUDTEMPLE_LLMAAS_BASE_URL=https://api.ai.cloud-temple.com/v1
# Modèle principal : Mistral Small 4 (catalogue Cloud Temple LLMaaS)
LLM_MODEL_MAIN=mistral-small4:119b
LLM_MODEL_FAST=mistral-small4:119b
LLM_MODEL_EMBED=bge-m3:567m
LLM_TIMEOUT_MS=20000

# --- MCP Assemblée nationale (tricoteuses) ---
MCP_TRICOTEUSES_URL=https://www.tricoteuses.fr/mcp
MCP_TIMEOUT_MS=15000

# --- Application ---
SESSION_SECRET=depulib-poc-changez-moi-32-caracteres
DATABASE_URL=file:/data/depulib.db
UPLOAD_DIR=/data/uploads
NEXT_PUBLIC_APP_NAME=Depulib
